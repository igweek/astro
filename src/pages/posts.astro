---
import PageHeading from "../components/page-heading.astro";
import PostsLoop from "../components/posts-loop.astro";
import Layout from "../layouts/main.astro";
import { getCollection } from "astro:content";

// 获取所有文章数据用于搜索
const allPosts = await getCollection("post");
---

<Layout title="My Writing">
  <section class="relative z-20 max-w-2xl mx-auto my-12 px-7 lg:px-0">
    <PageHeading
      title="My Writing"
      description="Dive into my musings on life and tech in my latest posts; a blend of introspection and innovation. Keep an eye out for fresh insights and updates!"
    />

    <!-- 搜索框 -->
    <div class="mb-8">
      <div class="relative">
        <input
          type="text"
          id="search-input"
          placeholder="搜索文章..."
          class="w-full px-4 py-3 pr-10 rounded-lg border border-neutral-300 dark:border-neutral-700 bg-white dark:bg-neutral-900 focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all"
        />
        <svg class="absolute right-3 top-1/2 transform -translate-y-1/2 w-5 h-5 text-neutral-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
        </svg>
      </div>
      <p id="search-results" class="mt-2 text-sm text-neutral-500 dark:text-neutral-400">
        显示所有文章
      </p>
    </div>

    <!-- 文章列表容器 -->
    <div id="posts-container" class="z-50 flex flex-col items-stretch w-full gap-5 my-8">
      <PostsLoop count="999999999" />
    </div>
  </section>

  <script is:inline>
    // 存储所有文章数据
    const postsData = {
      // 将文章数据转换为适合搜索的格式
      posts: [
        ...Object.entries(import.meta.glob('/src/content/post/*.md', { eager: true }))
          .map(([path, post]) => ({
            slug: path.split('/').pop().replace('.md', ''),
            title: post.frontmatter.title || '',
            description: post.frontmatter.description || '',
            date: post.frontmatter.dateFormatted || ''
          }))
      ]
    };

    // 获取DOM元素
    const searchInput = document.getElementById('search-input');
    const postsContainer = document.getElementById('posts-container');
    const resultsCount = document.getElementById('search-results');
    const originalPostsHtml = postsContainer.innerHTML;

    // 搜索功能实现
    searchInput.addEventListener('input', (e) => {
      const searchTerm = e.target.value.toLowerCase().trim();
      
      // 如果搜索词为空，显示所有文章
      if (!searchTerm) {
        postsContainer.innerHTML = originalPostsHtml;
        resultsCount.textContent = '显示所有文章';
        return;
      }
      
      // 过滤匹配的文章
      const matchingPosts = postsData.posts.filter(post => 
        post.title.toLowerCase().includes(searchTerm) || 
        post.description.toLowerCase().includes(searchTerm)
      );
      
      // 如果没有匹配结果
      if (matchingPosts.length === 0) {
        postsContainer.innerHTML = `
          <div class="text-center py-10">
            <p class="text-neutral-500 dark:text-neutral-400">没有找到匹配的文章</p>
            <button id="clear-search" class="mt-4 text-blue-600 dark:text-blue-400 hover:underline">
              清除搜索
            </button>
          </div>
        `;
        resultsCount.textContent = `找到 0 篇匹配的文章`;
        
        // 添加清除搜索按钮事件
        document.getElementById('clear-search').addEventListener('click', () => {
          searchInput.value = '';
          postsContainer.innerHTML = originalPostsHtml;
          resultsCount.textContent = '显示所有文章';
        });
        return;
      }
      
      // 显示匹配的文章
      const matchingSlugs = matchingPosts.map(post => post.slug);
      const tempContainer = document.createElement('div');
      tempContainer.innerHTML = originalPostsHtml;
      
      // 隐藏不匹配的文章
      tempContainer.querySelectorAll('[data-slug]').forEach(postEl => {
        const slug = postEl.getAttribute('data-slug');
        if (!matchingSlugs.includes(slug)) {
          postEl.style.display = 'none';
        } else {
          postEl.style.display = '';
        }
      });
      
      postsContainer.innerHTML = tempContainer.innerHTML;
      resultsCount.textContent = `找到 ${matchingPosts.length} 篇匹配的文章`;
    });
  </script>
</Layout>
